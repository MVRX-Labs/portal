        "original": "https://media.licdn.com/dms/image/v2/D4E03AQGCRNX95ii40Q/profile-displayphoto-crop_800_800/B4EZtMhTWpKkAI-/0/1766515357842?e=1775088000&v=beta&t=eOB2qttur_3vRPfqdXpKFiSjDGE8-PUfMsZQKE_4dho"
